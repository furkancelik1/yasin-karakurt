generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CLIENT
  TRAINER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ProgramStatus {
  DRAFT
  ACTIVE
  COMPLETED
  PAUSED
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
  PAUSED
}

enum SubscriptionPlan {
  BASIC
  PREMIUM
  VIP
}

enum CheckInStatus {
  PENDING
  REVIEWED
  COMPLETED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  role         Role      @default(CLIENT)
  isActive     Boolean   @default(true)
  isVerified   Boolean   @default(false)
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile       Profile?
  programs      Program[]         @relation("ClientPrograms")
  trainedBy     Program[]         @relation("TrainerPrograms")
  checkIns      CheckIn[]
  subscription  Subscription?
  notifications Notification[]
  userPrograms  UserProgram[]
  nutritionPlans NutritionPlan[]
  waterLogs     WaterLog[]

  @@map("users")
}

model Profile {
  id            String    @id @default(cuid())
  userId        String    @unique
  firstName     String
  lastName      String
  phone         String?
  dateOfBirth   DateTime?
  gender        Gender?
  avatarUrl     String?
  height        Float?
  weight        Float?
  fitnessGoal   String?
  medicalNotes  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model NutritionPlan {
  id             String    @id @default(cuid())
  userId         String
  title         String?
  targetCalories Int
  protein       Int
  carbs         Int
  fat           Int
  notes         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals        Meal[]

  @@index([userId])
  @@map("nutrition_plans")
}

model Meal {
  id          String    @id @default(cuid())
  planId     String
  name      String
  content   String    @db.Text
  time      String?
  isDone    Boolean   @default(false)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime @updatedAt

  plan       NutritionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("meals")
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  amount   Float    @db.Real
  date     DateTime @default(now())
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("water_logs")
}

model Program {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      ProgramStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  clientId    String
  trainerId   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client      User          @relation("ClientPrograms", fields: [clientId], references: [id])
  trainer     User          @relation("TrainerPrograms", fields: [trainerId], references: [id])
  weeks       ProgramWeek[]
  checkIns    CheckIn[]

  @@map("programs")
}

enum ProgramType {
  TRAINING
  NUTRITION
}

enum ProgramContentType {
  TEXT
  FILE
}

model UserProgram {
  id          String             @id @default(cuid())
  userId      String
  type        ProgramType
  title       String
  content     String?
  contentType ProgramContentType @default(TEXT)
  fileUrl     String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_programs")
}

model ProgramWeek {
  id        String        @id @default(cuid())
  programId String
  weekNumber Int
  title     String?
  days      WorkoutDay[]
  createdAt DateTime      @default(now())

  program   Program       @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, weekNumber])
  @@map("program_weeks")
}

model WorkoutDay {
  id          String      @id @default(cuid())
  weekId      String
  dayNumber   Int
  title       String?
  exercises   Exercise[]
  createdAt   DateTime    @default(now())

  week        ProgramWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([weekId, dayNumber])
  @@map("workout_days")
}

model Exercise {
  id          String     @id @default(cuid())
  dayId       String
  name        String
  sets        Int?
  reps        String?
  duration    String?
  restSeconds Int?
  notes       String?
  imageUrl    String?
  gifUrl      String?
  orderIndex  Int        @default(0)
  createdAt   DateTime   @default(now())

  day         WorkoutDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@map("exercises")
}

model CheckIn {
  id          String        @id @default(cuid())
  userId      String
  programId   String?
  weekNumber  Int?
  status     CheckInStatus @default(PENDING)
  
  // Metrikler
  weight       Float?
  bodyFat     Float?
  sleepHours  Int?
  energyLevel Int?
  stressLevel Int?
  hungerLevel Int?
  
  // Görseller
  frontPhotoUrl String?
  sidePhotoUrl String?
  backPhotoUrl String?
  photos      CheckInPhoto[]
  
  // Koç alanları
  coachNotes  String?
  rating     Int?
  
  notes       String?
  trainerNote String?
  submittedAt DateTime      @default(now())
  reviewedAt  DateTime?
  updatedAt  DateTime      @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  program    Program?  @relation(fields: [programId], references: [id])

  @@map("check_ins")
}

model CheckInPhoto {
  id         String   @id @default(cuid())
  checkInId  String
  url        String
  angle      String?
  createdAt  DateTime @default(now())

  checkIn    CheckIn  @relation(fields: [checkInId], references: [id], onDelete: Cascade)

  @@map("check_in_photos")
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @unique
  plan            SubscriptionPlan   @default(BASIC)
  status          SubscriptionStatus @default(PENDING)
  startDate       DateTime?
  endDate         DateTime?
  iyzicoToken     String?
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?
  priceAmount     Decimal?           @db.Decimal(10, 2)
  currency        String             @default("TRY")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id])
  payments        Payment[]

  @@map("subscriptions")
}

model Payment {
  id             String   @id @default(cuid())
  subscriptionId String
  amount         Decimal  @db.Decimal(10, 2)
  currency       String   @default("TRY")
  status         String
  iyzicoPaymentId String?
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}

enum NotificationType {
  PROGRAM_ASSIGNED
  CHECKIN_REMINDER
  SYSTEM
}

model Notification {
  id        String          @id @default(uuid())
  userId    String
  title     String
  message   String
  type     NotificationType @default(SYSTEM)
  isRead   Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

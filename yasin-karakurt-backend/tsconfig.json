{
  "compilerOptions": {
    /* Temel Ayarlar */
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    
    /* Katı Kurallar ve Güvenlik */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    
    /* Geliştirme ve Debug Ayarları */
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    /* Yol Tanımlamaları (baseUrl olmadan modern kullanım) */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}